{
  "testRunner": "jest",
  "jest": { "configFile": "jestconfig.stryker.json" },
  "mutate": ["src/**/*.ts", "!src/**/*.test.*", "!src/index.ts"],
  "reporters": ["clear-text", "progress"],
  "thresholds": { "high": 80, "low": 75, "break": 75 },
  "concurrency": 4,
  "timeoutMS": 30000,
  "ignoreStatic": true
}
